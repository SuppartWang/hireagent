# HireAgent API configuration
HIREAGENT_API_BASE_URL=https://hireagent-api.onrender.com/api/v1
HIREAGENT_ADMIN_EMAIL=admin@hireagent.ai
HIREAGENT_ADMIN_PASSWORD=demo1234

# Choose LLM provider: kimi | ollama | openai
LLM_PROVIDER=kimi

# Kimi (Moonshot) — OpenAI-compatible
KIMI_API_KEY=sk-...
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama local deployment
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Optional: Serper.dev API key for Google search
# SERPER_API_KEY=...

# Optional: GitHub token to raise rate limits
# GITHUB_TOKEN=ghp_...

# Pipeline configuration
MAX_AGENTS_PER_RUN=20
PUBLISH_ON_IMPORT=true
